    <pkg-ref id="com.tbwfdu.juice.app"/>
  </choice>
  <choice id="juice.runtime" visible="false" title="Juice Runtime">
    <pkg-ref id="com.tbwfdu.juice.runtime"/>
  </choice>
  <choice id="dep.01-munkitools-python-6.6.5.4711" visible="false" title="01-munkitools-python-6.6.5.4711">
